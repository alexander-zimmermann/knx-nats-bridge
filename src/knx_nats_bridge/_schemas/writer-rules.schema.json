{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alexander-zimmermann/knx-nats-bridge/schemas/writer-rules.schema.json",
  "title": "NATS-to-KNX writer rules",
  "description": "Declares which NATS subject's events drive which KNX group-address writes.",
  "type": "object",
  "properties": {
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subject":       { "type": "string", "minLength": 1 },
          "ga":            { "type": "string", "pattern": "^[0-9]+/[0-9]+/[0-9]+$" },
          "dpt":           { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
          "payload_path":  { "type": "string", "pattern": "^\\$(\\.[A-Za-z_][A-Za-z0-9_]*)*$" },
          "description":   { "type": "string" },
          "min_delta":     { "type": "number", "minimum": 0 },
          "min_delta_pct": { "type": "number", "minimum": 0 },
          "seed_on_start": { "type": "boolean" }
        },
        "required": ["subject", "ga", "dpt", "payload_path"],
        "additionalProperties": false
      }
    }
  },
  "required": ["mappings"],
  "additionalProperties": false
}
