{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alexander-zimmermann/knx-nats-bridge/schemas/knx-catalog.schema.json",
  "title": "KNX group-address catalog",
  "description": "Maps KNX group addresses to human names, DPTs, and ETS metadata (room, function, description).",
  "type": "object",
  "patternProperties": {
    "^[0-9]+/[0-9]+/[0-9]+$": {
      "type": "object",
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "dpt":         { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
        "room":        { "type": "string", "minLength": 1 },
        "function":    { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "required": ["name", "dpt"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
