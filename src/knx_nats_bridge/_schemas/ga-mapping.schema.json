{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alexander-zimmermann/knx-nats-bridge/schemas/ga-mapping.schema.json",
  "title": "KNX group-address mapping",
  "description": "Maps KNX group addresses to a human name and DPT.",
  "type": "object",
  "patternProperties": {
    "^[0-9]+/[0-9]+/[0-9]+$": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "dpt":  { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" }
      },
      "required": ["name", "dpt"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
